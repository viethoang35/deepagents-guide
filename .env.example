# Copy file này thành .env và điền key của bạn.
# Chỉ cần 1 trong các model provider dưới đây tuỳ model bạn chọn trong script.

# OpenRouter (1 key gọi nhiều model: deepseek, grok, gpt-4o-mini, ...)
# Đăng ký key tại https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Tavily (web search thật cho B2_advanced.py và B3_nemotron_deep_agent.py)
# Đăng ký key tại https://tavily.com (miễn phí có hạn mức)
TAVILY_API_KEY=tvly-your-key-here

# OpenAI (dự phòng)
# OPENAI_API_KEY=sk-your-key-here

# Anthropic (dự phòng)
# ANTHROPIC_API_KEY=sk-ant-...

# Google (dự phòng)
# GOOGLE_API_KEY=...

# Local model (Ollama) — khi dùng "olama:llama3.1"
# không cần key, nhưng phải bật Ollama:  ollama serve
# OPENAI_API_KEY=not-needed

# --- B2: model mặc định (dùng cho B2_quickstart.py và B2_advanced.py) ---
# Định dạng openrouter: <provider>/<model>
# Ví dụ:
#   DEEPAGENTS_MODEL=openrouter:deepseek/deepseek-chat-v3
#   DEEPAGENTS_MODEL=openrouter:x-ai/grok-4.5
#   DEEPAGENTS_MODEL=openrouter:openai/gpt-4o-mini
DEEPAGENTS_MODEL=openrouter:openai/gpt-4o-mini

# --- B3: multi-model (dùng cho B3_nemotron_deep_agent.py) ---
# Orchestrator: model mạnh, planning/synthesis (như frontier model bên NVIDIA)
ORCHESTRATOR_MODEL=openrouter:x-ai/grok-4.5
# Researcher sub-agent: model rẻ/nhanh, làm volume work (như Nemotron Super bên NVIDIA)
RESEARCHER_MODEL=openrouter:deepseek/deepseek-chat-v3

# --- Tuỳ chọn: LangSmith tracing (áp dụng cho MỌI script, không cần sửa code) ---
# Bật để xem trajectory đầy đủ (tool call, sub-agent, token) trên smith.langchain.com
# thay vì chỉ đọc log console. Đăng ký key tại https://smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=deepagents-guide
