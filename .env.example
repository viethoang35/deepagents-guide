# Copy this file to .env and fill in your key.
# You only need one of the model providers below, depending on which model you pick in the script.

# OpenRouter (1 key calls many models: deepseek, grok, gpt-4o-mini, ...)
# Register a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Tavily (real web search for B2_advanced.py and B3_nemotron_deep_agent.py)
# Register a key at https://tavily.com (free tier with limits)
TAVILY_API_KEY=tvly-your-key-here

# OpenAI (fallback)
# OPENAI_API_KEY=sk-your-key-here

# Anthropic (fallback)
# ANTHROPIC_API_KEY=sk-ant-...

# Google (fallback)
# GOOGLE_API_KEY=...

# Local model (Ollama) — when using "ollama:llama3.1"
# no key needed, but Ollama must be running:  ollama serve
# OPENAI_API_KEY=not-needed

# --- B2: default model (used by B2_quickstart.py and B2_advanced.py) ---
# Format: openrouter:<provider>/<model>
# Examples:
#   DEEPAGENTS_MODEL=openrouter:deepseek/deepseek-chat-v3
#   DEEPAGENTS_MODEL=openrouter:x-ai/grok-4.5
#   DEEPAGENTS_MODEL=openrouter:openai/gpt-4o-mini
DEEPAGENTS_MODEL=openrouter:openai/gpt-4o-mini

# --- B3: multi-model (used by B3_nemotron_deep_agent.py) ---
# Orchestrator: strong model, planning/synthesis (like NVIDIA's frontier model)
ORCHESTRATOR_MODEL=openrouter:x-ai/grok-4.5
# Researcher sub-agent: cheap/fast model, does the volume work (like NVIDIA's Nemotron Super)
RESEARCHER_MODEL=openrouter:deepseek/deepseek-chat-v3

# --- B9 live: GitHub API access (used by B9_pr_review_agent_live.py) ---
# Fine-grained personal access token scoped to the target repo, with
# "Pull requests: Read and write" AND "Issues: Read and write" permissions
# (posting a PR comment uses the issue-comments endpoint under the hood).
# Create one at https://github.com/settings/personal-access-tokens/new
# GITHUB_TOKEN=github_pat_...

# --- Optional: LangSmith tracing (applies to EVERY script, no code changes needed) ---
# Enable to see the full trajectory (tool calls, sub-agents, tokens) on smith.langchain.com
# instead of just reading console logs. Register a key at https://smith.langchain.com
# LANGCHAIN_TRACING_V2 is the current standard env var; LANGSMITH_TRACING is an older
# alias some LangChain versions still read — set LANGCHAIN_TRACING_V2, no need for both.
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=deepagents-guide

# --- B8: LangSmith eval dataset name (used by B8_langsmith_eval.py) ---
# LANGSMITH_EVAL_DATASET=repo-ops-eval
